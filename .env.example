PORT=5173
HOST=localhost
DB_CLIENT=sqlite
SQLITE_FILE=./data.db

# Docker Compose sets DB_CLIENT=postgres and uses these PostgreSQL settings.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=playground
POSTGRES_USER=app_user

# Render can set POSTGRES_PASSWORD directly. Docker Compose can continue using POSTGRES_PASSWORD_FILE.
# If both are present, POSTGRES_PASSWORD wins.
# POSTGRES_PASSWORD=change-me
POSTGRES_PASSWORD_FILE=./secrets/postgres_app_password.txt
POSTGRES_SSLMODE=require

# Optional Render-style connection string. If set, it is used instead of the individual host/db/user fields.
# DATABASE_URL=postgresql://user:password@host:5432/database
