# Copy this file to .env for local npm start.
# Render uses dashboard environment variables instead of this file.

# Shared local server settings
PORT=5173
HOST=localhost

# Option 1: SQLite local fallback
DB_CLIENT=sqlite
SQLITE_FILE=./data.db

# Option 2: PostgreSQL local npm start
# Use this when connecting npm start to a local PostgreSQL instance.
# Keep POSTGRES_SSLMODE=disable for a typical local non-TLS database.
# DB_CLIENT=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=playground
# POSTGRES_USER=app_user
# POSTGRES_PASSWORD=change-me
# POSTGRES_SSLMODE=disable

# Option 3: Render PostgreSQL
# Set these in the Render dashboard, not in a committed .env file.
# DB_CLIENT=postgres
# DATABASE_URL=postgresql://user:password@host:5432/database
# POSTGRES_PASSWORD=change-me
# POSTGRES_SSLMODE=require

# Docker Compose compatibility
# Compose sets DB_CLIENT=postgres and uses POSTGRES_PASSWORD_FILE inside the app container.
# If both POSTGRES_PASSWORD and POSTGRES_PASSWORD_FILE are present, POSTGRES_PASSWORD wins.
# POSTGRES_PASSWORD_FILE=./secrets/postgres_app_password.txt
